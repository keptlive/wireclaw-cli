# WireClaw Configuration

# Claude authentication (one of these required)
# CLAUDE_CODE_OAUTH_TOKEN=
# ANTHROPIC_API_KEY=

# Optional: default Claude model (overridden per-group if set)
# CLAUDE_MODEL=claude-sonnet-4-5-20250514

# Optional: AgentWire integration
# One API key for all your agents. Each group auto-creates its own agent
# on AgentWire with its own email, memory, and talk page.
# AGENTWIRE_API_KEY=am_live_xxx
# AGENTWIRE_URL=https://agentwire.run
